{
  "name": "vscode-launchpad",
  "version": "1.0.0",
  "description": "View, search, and open all your VS Code workspaces from one place",
  "main": "server/index.js",
  "scripts": {
    "start": "npm run build && node server/index.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:react\"",
    "dev:server": "node server/index.js",
    "dev:react": "PORT=${DASHBOARD_DEV_PORT:-3020} BROWSER=none react-scripts start",
    "build": "react-scripts build && rm -rf public/static public/index.html public/asset-manifest.json && cp -r build/* public/",
    "build:react": "react-scripts build",
    "build:sidecar": "node scripts/build-sidecar.js",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:full": "npm run build:sidecar && tauri build",
    "test": "react-scripts test --watchAll=false",
    "test:watch": "react-scripts test",
    "test:server": "jest --config jest.server.config.js",
    "test:server:watch": "jest --config jest.server.config.js --watch",
    "test:coverage": "react-scripts test --watchAll=false --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:server"
  },
  "keywords": [
    "vscode",
    "workspace",
    "dashboard"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "axios": "^1.6.0",
    "express": "^4.18.2",
    "fs-extra": "^11.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "concurrently": "^9.2.1",
    "pkg": "^5.8.1",
    "react-scripts": "^5.0.1",
    "supertest": "^7.2.2"
  },
  "jest": {
    "transformIgnorePatterns": [
      "/node_modules/(?!(@tauri-apps)/)"
    ],
    "moduleNameMapper": {
      "@tauri-apps/api/core": "<rootDir>/src/__mocks__/@tauri-apps/api/core.js",
      "@tauri-apps/api/event": "<rootDir>/src/__mocks__/@tauri-apps/api/event.js",
      "@tauri-apps/plugin-shell": "<rootDir>/src/__mocks__/@tauri-apps/plugin-shell.js",
      "@tauri-apps/plugin-dialog": "<rootDir>/src/__mocks__/@tauri-apps/plugin-dialog.js"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}

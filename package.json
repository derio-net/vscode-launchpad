{
  "name": "vscode-workspace-dashboard",
  "version": "1.0.0",
  "description": "A dashboard to view and manage VS Code workspaces",
  "main": "server/index.js",
  "scripts": {
    "start": "npm run build && node server/index.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:react\"",
    "dev:server": "node server/index.js",
    "dev:react": "PORT=${DASHBOARD_DEV_PORT:-3020} BROWSER=none react-scripts start",
    "build": "react-scripts build && cp -r build/* public/",
    "build:react": "react-scripts build",
    "build:sidecar": "npx pkg server/index.js --targets node18-macos-arm64 --output src-tauri/binaries/sidecar-vscode-dashboard-aarch64-apple-darwin",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "vscode",
    "workspace",
    "dashboard"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "axios": "^1.6.0",
    "express": "^4.18.2",
    "fs-extra": "^11.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.0",
    "concurrently": "^9.2.1",
    "pkg": "^5.8.1",
    "react-scripts": "^5.0.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}

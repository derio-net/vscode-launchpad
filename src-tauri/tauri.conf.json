{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "VS Code Launchpad",
  "version": "1.0.0",
  "identifier": "com.vscodeworkspacedashboard.desktop",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:3020",
    "beforeDevCommand": "npm run dev:react",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "VS Code Launchpad",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:3010 http://localhost:3010 http://127.0.0.1:3020 http://localhost:3020; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/sidecar-vscode-dashboard"
    ],
    "resources": [
      "icons/32x32.png"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://api.github.com/repos/derio-net/vscode-launchpad/releases/latest"
      ],
      "dialog": true,
      "pubkey": "YOUR_UPDATER_SIGNATURE_PUBKEY_HERE"
    }
  }
}
